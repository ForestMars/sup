{
  "name": "'Sup",
  "type": "module",
  "version": "0.0.3",
  "workspaces": [
    "apps/cli",
    "packages/tsconfig",
    "packages/domain",
    "packages/agents",
    "packages/infra",
    "packages/tools",
    "packages/lib",
    "types"
  ],
  "main": "index.js",
  "scripts": {
    "agent:test": "bun tests/test-agent.ts",
    "app": "NODE_ENV=production bun apps/cli/chat.ts",
    "build": "bun run type-check && vite build",
    "build:ci": "bun run build && bun run test:ci",
    "build:dev": "vite build --mode development",
    "chat": "bun apps/cli/chat.ts",
    "chat:loki": "LOKI_ENABLED=true bun apps/cli/chat.ts",
    "lint": "eslint . --cache --max-warnings 0",
    "lint:fix": "eslint . --cache --fix --max-warnings 0",
    "preview": "vite preview",
    "test": "bun test ./tests/e2e/e2e.test.ts",
    "test:once": "bun test",
    "test:ui": "bun test",  
    "test:cov": "bun test --coverage ./src/**/*.test.ts ./tests/**/*.test.ts",
    "test:bail": "bun test --coverage --bail ./packages/**/*.test.ts",
    "test:watch": "bun test --watch",
    "tests": "bun test ./tests/**/*.test.ts",
    "tests:int": "bun test ./tests/integration/*.test.ts",
    "tests:unit": "bun test ./tests/unit/*.test.ts",
    "type-check": "tsc --build",
    "clean": "rm -rf dist && tsc --build --clean",
    "clean:fr": "find . -name 'dist' -type d -prune -exec rm -rf {} + && find . -name '*.tsbuildinfo' -delete && tsc --build --clean",
    "clean:nuke": "find . -type f \\( -name '*.js' -o -name '*.d.ts' -o -name '*.d.ts.map' -o -name '*.js.map' -o -name '*.tsbuildinfo' \\) -not -path '*/node_modules/*' -delete && find . -name 'dist' -type d -prune -exec rm -rf {} +",
    "reinstall": "bun pm cache rm && rm -rf node_modules && bun install",
    "rebuild": "bun run clean:dist && bun run clean:tsbuildinfo && bun tsc --build --force"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@openfeature/core": "1.9.2",
    "@openfeature/flagd-provider": "^0.13.4",
    "@openfeature/server-sdk": "1.20.2",
    "@tanstack/ai": "^0.6.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-table": "^8.21.3",
    "@tapico/node-openfeature-posthog": "1.1.3",
    "@types/bun": "^1.3.10",
    "ai": "*",
    "ai-sdk-ollama": "^3.8.0",
    "pino": "^10.3.1",
    "pino-loki": "2.0.0",
    "pino-opentelemetry-transport": "^3.0.0",
    "posthog-node": "^5.26.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.10",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "trustedDependencies": [
    "@openfeature/server-sdk",
    "@tapico/node-openfeature-posthog",
    "pino-loki"
  ]
}
