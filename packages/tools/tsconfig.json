{
  "extends": "../tsconfig/base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@sup/lib": ["../lib/index.ts"]
    },
    "types": ["node", "bun-types"],
    "resolveJsonModule": true
  },
  "references": [ 
    {"path": "../domain"},
    {"path": "../lib" }
  ],
  "include": ["**/*.ts", "registry.json"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/test.ts"]
}
